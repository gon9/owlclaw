<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>{{ data.headline }}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    width: 1280px; height: 720px;
    font-family: "Hiragino Sans", "Yu Gothic", "Noto Sans JP", sans-serif;
    background: #ffffff;
    color: #1a2e4a;
    padding: 28px 36px;
    display: flex; flex-direction: column;
  }
  .headline {
    font-size: 30px; font-weight: 800;
    border-left: 8px solid #1a2e4a;
    padding-left: 16px; line-height: 1.2;
  }
  .headline em { color: #e87421; font-style: normal; }
  .subtitle {
    font-size: 15px; color: #555;
    margin: 14px 0 18px 24px; line-height: 1.55;
  }
  .columns {
    display: grid;
    grid-template-columns: repeat({{ data.columns | length }}, 1fr);
    gap: 16px;
    margin-bottom: 20px;
    flex: 1;
  }
  .col {
    border: 2px solid #1a2e4a;
    border-radius: 6px;
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .col-label {
    background: #1a2e4a; color: #fff;
    font-size: 16px; font-weight: 700;
    padding: 8px 12px; text-align: center;
  }
  .col-body {
    padding: 24px 12px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    flex: 1;
  }
  .col-value {
    font-size: 56px; font-weight: 800;
    color: #e87421;
    line-height: 1;
    text-align: center;
  }
  .col-caption {
    font-size: 13px; color: #555;
    margin-top: 14px; text-align: center;
  }
  .insights {
    background: #f7f3ee;
    border-left: 4px solid #e87421;
    padding: 12px 18px;
    margin-bottom: 12px;
  }
  .insights-title {
    font-size: 14px; font-weight: 700;
    color: #1a2e4a;
    margin-bottom: 6px;
  }
  .insights-list {
    font-size: 13px; color: #333;
    line-height: 1.7;
    padding-left: 20px;
  }
  .footer {
    font-size: 11px; color: #888;
    text-align: left;
    border-top: 1px solid #ccc;
    padding-top: 6px;
  }
</style>
</head>
<body>

<div class="headline">{{ data.headline }}</div>
{% if data.subtitle %}<div class="subtitle">{{ data.subtitle }}</div>{% endif %}

<div class="columns">
  {% for col in data.columns %}
  <div class="col">
    <div class="col-label">{{ col.label }}</div>
    <div class="col-body">
      <div class="col-value">{{ col.value }}</div>
      {% if col.caption %}<div class="col-caption">{{ col.caption }}</div>{% endif %}
    </div>
  </div>
  {% endfor %}
</div>

{% if data.insights %}
<div class="insights">
  <div class="insights-title">💡 戦略的示唆</div>
  <ul class="insights-list">
    {% for insight in data.insights %}<li>{{ insight }}</li>{% endfor %}
  </ul>
</div>
{% endif %}

{% if data.source %}<div class="footer">Source: {{ data.source }} | OWLCLAW NEWS</div>{% endif %}

</body>
</html>
